    {
      "parameters": {
        "promptType": "define",
        "text": "=title: {{ $json.title }}\ndate: {{ $json.date }}\nattendees: {{ $json.attendees }}\ntranscript: {{ $json.transcript }}",
        "options": {
          "systemMessage": "You are a meeting assistant that extracts structured data from meeting transcripts.\n\nYour task:\n1. Read the meeting title, date, attendees, and transcript.\n2. Extract:\n   - summary: short summary (2–4 sentences)\n   - decisions: list of key decisions made\n   - action_items: list of action items with:\n       - title: short action title\n       - description: 1–2 sentences\n       - owner: person name or null if not mentioned\n       - due_date: date string or null if not mentioned\n       - priority: \"low\", \"medium\", or \"high\" (infer from context)\n       - status: \"pending\"\n   - open_questions: unresolved questions\n   - next_steps: immediate next steps\n   - risks_blockers: risks or blockers mentioned\n\nReturn ONLY valid JSON in this exact schema:\n{\n  \"summary\": \"string\",\n  \"decisions\": [{\"title\": \"string\", \"owner\": \"string|null\"}],\n  \"action_items\": [\n    {\n      \"title\": \"string\",\n      \"description\": \"string\",\n      \"owner\": \"string|null\",\n      \"due_date\": \"string|null\",\n      \"priority\": \"low|medium|high\",\n      \"status\": \"pending\"\n    }\n  ],\n  \"open_questions\": [\"string\"],\n  \"next_steps\": [\"string\"],\n  \"risks_blockers\": [\"string\"]\n}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        464,
        -144
      ],
      "id": "c0d1b34e-c774-4cd8-bf3a-fe7367977112",
      "name": "Extract Meeting Data"
    },
    {
      "parameters": {
        "jsCode": "const meetingData = $('Validate Input').first().json;\nconst item = $('Map').first();\nconst output = [];\n\n  const json = item.json.output;\n  const { title, date, attendees } = meetingData;\n\n  const meetingId = `M-${date || 'unknown'}-${Math.floor(Math.random()*10000)}`;\n\n  const actions = json.action_items || [];\n  const normalizedActions = actions.map((a, i) => ({\n    id: `AI-${String(i+1).padStart(3, '0')}`,\n    meeting_id: meetingId,\n    meeting_title: title,\n    meeting_date: date,\n    title: a.title || 'Untitled action',\n    description: a.description || '',\n    owner: a.owner || null,\n    due_date: a.due_date || null,\n    priority: ['low','medium','high'].includes(a.priority) ? a.priority : 'medium',\n    status: a.status || 'pending'\n  }));\n\n  output.push({\n    json: {\n      ...json,\n      meeting_id: meetingId,\n      action_items: normalizedActions\n    }\n  });\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
