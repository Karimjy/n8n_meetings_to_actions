      "id": "888ff3f8-ed67-4b49-b906-e63f6d088d6f",
      "name": "OpenRouter Chat Model",
      "credentials": {
        "openRouterApi": {
          "id": "iFTvKTGgnvs0aSZz",
          "name": "OpenRouter account"
        }
      }
